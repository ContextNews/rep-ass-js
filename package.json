{
  "name": "rep-ass-js",
  "version": "0.0.1",
  "description": "Config-driven layout library for visualising representative assemblies (UN, US Senate, UK Commons, EU Parliament, etc.).",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "vite",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/d3-selection": "^3.0.10",
    "d3-selection": "^3.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  },
  "keywords": [
    "d3",
    "visualization",
    "parliament",
    "assembly",
    "hemicycle",
    "senate",
    "congress",
    "svg"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ContextNews/rep-ass-js.git"
  },
  "license": "MIT",
  "author": "Euan Campbell"
}
